generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id        Int        @id @default(autoincrement())
  name      String
  category  String     @default("Premium")
  price     Float      
  abilities String     
  imageIds  String[]   
  sizes     String[]   
  colors    String[]   
  stock     Int        @default(100)
  rating    Float      @default(5.0) 
  createdAt DateTime   @default(now())
  purchases Purchase[] 
}

model User {
  id                 Int        @id @default(autoincrement())
  email              String?    @unique
  password           String?   
  telegramId         String?    @unique 
  firstName          String?
  country            String     @default("BD") 
  balanceBdt         Float      @default(0.0) 
  loyaltyPoints      Int        @default(0)
  savedAddress       String?
  refCode            String?    @unique 
  referredBy         String?    
  referralRewardPaid Boolean    @default(false)
  refCount           Int        @default(0)
  ipAddress          String?    
  isVip              Boolean    @default(false)
  vipExpiry          DateTime?
  isBanned           Boolean    @default(false)
  role               String     @default("USER") // USER, ADMIN, OWNER, PENDING_ADMIN
  location           String?    
  avatar             String?
  isVerified         Boolean    @default(false)
  verifyToken        String?
  resetToken         String?    
  resetCode          String?    
  resetExpiry        DateTime?
  lastRedeemDate     DateTime?  
  deposits           Deposit[] 
  purchases          Purchase[] 
  createdAt          DateTime   @default(now())
}

model Rider {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  phone         String
  password      String
  avatar        String?  
  deliveryCount Int      @default(0) 
  walletBalance Float    @default(0.0) 
  totalEarned   Float    @default(0.0) 
  lastLat       Float?   
  lastLng       Float?   
  lastLocUpdate DateTime? 
  isVerified    Boolean  @default(false)
  verifyToken   String?
  withdraws     RiderWithdraw[] 
  createdAt     DateTime @default(now())
}

model Promo {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  discount  Int      
  isActive  Boolean  @default(true)
}

model RedeemCode {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  amount    Float
  maxUses   Int      @default(1)
  usedBy    Int[]    
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Deposit {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  method        String   
  amountBdt     Float    
  senderNumber  String   
  trxId         String   @unique
  status        String   @default("PENDING") 
  createdAt     DateTime @default(now())
}

model Purchase {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  productId     Int
  product       Product  @relation(fields: [productId], references: [id])
  selectedSize  String?  
  selectedColor String?  
  priceTotal    Float    
  advancePaid   Float    
  dueCod        Float    
  promoApplied  String?  
  phone         String?  
  street        String?  
  city          String?  
  postcode      String?  
  status        String   @default("PENDING") 
  deliveryOtp   String?  
  deliveredBy   String?  
  createdAt     DateTime @default(now())
}

model Notice {
  id        Int      @id @default(autoincrement())
  text      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model FlashSale {
  id              Int      @id @default(1)
  isActive        Boolean  @default(false)
  endTime         DateTime @default(now())
  discountPercent Int      @default(0)
}

model RiderWithdraw {
  id        Int      @id @default(autoincrement())
  riderId   Int
  rider     Rider    @relation(fields: [riderId], references: [id])
  amount    Float
  method    String
  number    String
  status    String   @default("PENDING") 
  createdAt DateTime @default(now())
}

// 🔥 UPDATED DEFAULT CONFIG WITH BKASH/NAGAD & FB LINK
model StoreConfig {
  id          Int      @id @default(1)
  ownerName   String   @default("Ononto Hasan")
  ownerPhone  String   @default("+8801846849460")
  ownerBio    String   @default("Store Founder & Freestyle Player")
  fbLink      String   @default("https://www.facebook.com/yours.ononto")
  tgLink      String   @default("https://t.me/minato_namikaze143")
  bkashNumber String   @default("01846849460")
  nagadNumber String   @default("01846849460")
}

model SystemAdmin {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String
  location  String
  password  String
  createdAt DateTime @default(now())
}
