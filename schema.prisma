generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id        Int        @id @default(autoincrement())
  name      String
  price     Float      
  abilities String     
  imageIds  String[]   
  sizes     String[]   
  colors    String[]   
  stock     Int        @default(100)
  rating    Float      @default(5.0) 
  createdAt DateTime   @default(now())
  purchases Purchase[] 
}

model User {
  id                 Int        @id @default(autoincrement())
  email              String?    @unique
  password           String?   
  telegramId         String?    @unique 
  firstName          String?
  country            String     @default("BD") 
  balanceBdt         Float      @default(0.0) 
  refCode            String?    @unique 
  referredBy         String?    
  referralRewardPaid Boolean    @default(false)
  refCount           Int        @default(0)
  ipAddress          String?    
  isVip              Boolean    @default(false)
  vipExpiry          DateTime?
  isBanned           Boolean    @default(false)
  role               String     @default("USER")
  avatar             String?
  isVerified         Boolean    @default(false)
  verifyToken        String?
  resetToken         String?
  resetCode          String?    
  resetExpiry        DateTime?
  deposits           Deposit[] 
  purchases          Purchase[] 
  createdAt          DateTime   @default(now())
}

// 🔥 NEW RIDER MODEL
model Rider {
  id          Int      @id @default(autoincrement())
  name        String
  email       String   @unique
  phone       String
  password    String
  isVerified  Boolean  @default(false)
  verifyToken String?
  createdAt   DateTime @default(now())
}

model Promo {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  discount  Int      
  isActive  Boolean  @default(true)
}

model Deposit {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  method        String   
  amountBdt     Float    
  senderNumber  String   
  trxId         String   @unique
  status        String   @default("PENDING") 
  createdAt     DateTime @default(now())
}

model Purchase {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  productId     Int
  product       Product  @relation(fields: [productId], references: [id])
  selectedSize  String?  
  selectedColor String?  
  priceTotal    Float    
  advancePaid   Float    
  dueCod        Float    
  phone         String?  
  street        String?  
  city          String?  
  postcode      String?  
  status        String   @default("PENDING") 
  deliveryOtp   String?  
  deliveredBy   String?  // 🔥 Track which rider delivered
  createdAt     DateTime @default(now())
}

model Notice {
  id        Int      @id @default(autoincrement())
  text      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}
